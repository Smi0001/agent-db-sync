# agent-db-sync — DB connection credentials
# Copy this file to .env and fill in values. .env is gitignored.

# ---- sandman ----
# Reach via SSH tunnel:  ssh -N -L 5433:localhost:5432 <ssh-host>
PG_SANDMAN_HOST=127.0.0.1
PG_SANDMAN_PORT=5433
PG_SANDMAN_DATABASE=
PG_SANDMAN_USER=
PG_SANDMAN_PASSWORD=
PG_SANDMAN_SSH=
PG_SANDMAN_REMOTE_PORT=5432

# ---- UAT ----
# Reach via SSH tunnel:  ssh -N -L 5434:localhost:5432 <ssh-host>
PG_UAT_HOST=127.0.0.1
PG_UAT_PORT=5434
PG_UAT_DATABASE=
PG_UAT_USER=
PG_UAT_PASSWORD=
PG_UAT_SSH=
PG_UAT_REMOTE_PORT=5432

# ---- local ----
PG_LOCAL_HOST=localhost
PG_LOCAL_PORT=5432
PG_LOCAL_DATABASE=
PG_LOCAL_USER=
PG_LOCAL_PASSWORD=
