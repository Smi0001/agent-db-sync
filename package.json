{
  "name": "@smi0001/agent-db-sync",
  "version": "0.1.0",
  "description": "Sync remote Postgres databases (sandman/UAT/staging) to local with Sequelize migration reconciliation.",
  "author": "Shammi Hans",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent-db-sync": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    ".dbsync.example.json"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "postgres",
    "postgresql",
    "sequelize",
    "migrations",
    "database",
    "sync",
    "developer-tools",
    "cli"
  ],
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "dotenv": "^16.4.5",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
